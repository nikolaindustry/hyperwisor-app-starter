# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored — your keys never get committed.
#
# Leave these unset (or delete .env.local) to run the app in MOCK MODE.

# Hyperwisor manufacturer API key (starts with mk_)
VITE_HW_API_KEY=

# Hyperwisor manufacturer secret key (starts with msk_)
# WARNING: do not ship this in production mobile builds. See docs/SECURITY.md.
VITE_HW_SECRET_KEY=

# Optional overrides — defaults are fine for the standard Hyperwisor backend.
# VITE_HW_API_BASE_URL=https://cgsuxlbravclbbpnvfky.supabase.co/functions/v1
# VITE_HW_REALTIME_URL=wss://nikolaindustry-realtime.onrender.com

# Optional: required only when app.config.ts mode is "single-product"
# VITE_HW_PRODUCT_ID=
